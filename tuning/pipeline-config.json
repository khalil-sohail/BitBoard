{
  "schemaVersion": 1,
  "pipelineVersion": "21.2",
  "dataset": {
    "minPly": 12,
    "sampleEvery": 1,
    "splitSeed": "bitboard-pipeline-split-v1",
    "trainRatio": 80,
    "validationRatio": 10,
    "testRatio": 10
  },
  "modes": {
    "prototype": {
      "minimumAcceptedGames": 20,
      "minimumFinalPositions": 200,
      "dataset": {
        "maximumAcceptedGames": 10000,
        "scanAllInputGames": false,
        "maximumRetainedPositions": 100000,
        "maximumPositionsPerGame": 6,
        "phaseQuotas": {"opening": 2, "middlegame": 3, "endgame": 1}
      },
      "selection": {"train": 700, "validation": 150, "test": 150, "maxPerGame": 2},
      "auditPositions": 60,
      "stockfishNodes": 1000,
      "evaluationSearchPositions": 48,
      "searchDevelopment": 32,
      "searchHoldout": 16,
      "searchDepth": 3,
      "smokeMaximumPlies": 40
    },
    "full": {
      "minimumAcceptedGames": 1000,
      "minimumFinalPositions": 50000,
      "dataset": {
        "maximumAcceptedGames": null,
        "scanAllInputGames": true,
        "maximumRetainedPositions": 1000000,
        "maximumPositionsPerGame": 8,
        "phaseQuotas": {"opening": 2, "middlegame": 4, "endgame": 2}
      },
      "selection": {"train": 50000, "validation": 5000, "test": 5000, "maxPerGame": 2},
      "auditPositions": 2000,
      "stockfishNodes": 100000,
      "evaluationSearchPositions": 300,
      "searchDevelopment": 300,
      "searchHoldout": 150,
      "searchDepth": 6,
      "smokeMaximumPlies": 160
    }
  },
  "annotation": {
    "threads": 1,
    "hashMb": 256,
    "multiPv": 1,
    "checkpointEvery": 10,
    "minimumCpCoveragePercent": 90
  },
  "evaluationFitting": {
    "allowlistPolicy": "phase15-tracked-allowlist",
    "cpClip": 1500,
    "maxParameterDelta": 20,
    "seed": "bitboard-eval-selection-v2",
    "disconnectedFeatures": ["evaluation.pawns.passedBlockedDivisor"]
  },
  "evaluationValidation": {"searchDepth": 4, "smokeDepth": 3},
  "searchTuning": {
    "oneAtATime": true,
    "parameters": ["search.aspiration.windowCp", "search.nullMove.reduction", "search.quiescence.deltaPruningMarginCp"]
  },
  "time": {"tuneByDefault": false, "formulaRemediation": false},
  "opening": {"book": "engine/openings/performance.bin"},
  "regressions": {"fullWebsiteVerification": false},
  "match": {
    "runByDefault": false,
    "minimumGames": 1000,
    "depth": 2,
    "timeControl": "depth 2",
    "colorReversal": true
  },
  "promotion": {"prepareWhenEligible": true, "automaticPromotion": false},
  "resources": {
    "maximumDatasetRssMb": 8192,
    "warningDatasetRssMb": 6144,
    "minimumFreeMemoryMb": 4096,
    "minimumFreeDiskGb": 20,
    "averageExportBytesPerRecord": 900,
    "averageSqliteBytesPerRecord": 2500
  },
  "clean": {"requireConfirmation": true}
}
