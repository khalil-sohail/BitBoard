{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:full",
    "dev:frontend": "node scripts/run-with-port.mjs frontend development -- next dev",
    "dev:backend": "node scripts/run-with-port.mjs backend development BACKEND_ONLY=true ENGINE_PATH=../engine/chess-engine -- ts-node --project tsconfig.server.json server.ts",
    "dev:full": "node scripts/run-with-port.mjs full-stack development ENGINE_PATH=../engine/chess-engine -- ts-node --project tsconfig.server.json server.ts",
    "dev:engine": "make -C ../engine",
    "dev:server": "npm run dev:backend",
    "dev:all": "npm run dev:engine && npm run dev:full",
    "build": "npm run build:all",
    "build:frontend": "next build",
    "build:server": "tsc --project tsconfig.server.json",
    "build:all": "npm run build:frontend && npm run build:server",
    "start": "npm run start:full",
    "start:frontend": "node scripts/run-with-port.mjs frontend production -- node scripts/start-standalone.mjs",
    "start:backend": "node scripts/run-with-port.mjs backend production BACKEND_ONLY=true -- node dist/server.js",
    "start:full": "node scripts/run-with-port.mjs full-stack production -- node dist/server.js",
    "start:server": "npm run start:full",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --pretty false",
    "test:queue": "ts-node --project tsconfig.server.json src/lib/engine-session.queue.test.ts",
    "test:protocol": "ts-node --project tsconfig.server.json src/lib/engine-session.protocol.test.ts",
    "test:fair-play": "ts-node --project tsconfig.server.json src/lib/fair-play-engine.test.ts",
    "test:fair-play-integration": "ts-node --project tsconfig.server.json src/lib/fair-play-engine.integration.test.ts",
    "test:engine-filter": "ts-node --project tsconfig.server.json src/lib/engine-response-filter.test.ts",
    "test:evaluation": "ts-node --project tsconfig.server.json src/lib/engine-evaluation.test.ts",
    "test:difficulty": "ts-node --project tsconfig.server.json src/lib/engine-difficulty.test.ts",
    "test:terminal": "ts-node --project tsconfig.server.json src/lib/engine-terminal.test.ts",
    "test:time-policy": "ts-node --project tsconfig.server.json src/lib/time-management-policy.test.ts",
    "test:search-policy": "ts-node --project tsconfig.server.json src/lib/search-policy.test.ts",
    "test:promotion": "ts-node --project tsconfig.server.json src/lib/promotion.test.ts",
    "test:training-hint": "ts-node --project tsconfig.server.json src/lib/training-hint.test.ts",
    "test:training-machine": "ts-node --project tsconfig.server.json src/lib/training-machine.test.ts",
    "test:board-arrows": "ts-node --project tsconfig.server.json src/lib/board-arrows.test.ts",
    "test:ownership": "ts-node --project tsconfig.server.json src/components/engine-ownership.test.ts",
    "test:layout": "ts-node --project tsconfig.server.json src/components/layout/responsive-layout.test.ts",
    "test:controller": "ts-node --project tsconfig.server.json src/session/session-controller-boundary.test.ts",
    "test:setup": "ts-node --project tsconfig.server.json src/components/setup/session-setup.test.ts",
    "test:fair-play-ui": "ts-node --project tsconfig.server.json src/components/fair-play/fair-play-sidebar.test.ts",
    "test:training-ui": "ts-node --project tsconfig.server.json src/components/training/training-sidebar.test.ts",
    "test:analysis-ui": "ts-node --project tsconfig.server.json src/components/analysis/analysis-sidebar.test.ts",
    "test:live-data": "ts-node --project tsconfig.server.json src/components/live-data/live-data.test.ts",
    "test:result-acknowledgment": "ts-node --project tsconfig.server.json src/lib/engine-result-ownership.test.ts",
    "test:result-acknowledgment-integration": "node scripts/result-acknowledgment.browser.integration.mjs",
    "test:config": "ts-node --project tsconfig.server.json src/lib/server-config.test.ts",
    "test:server": "npm run test:config && npm run test:queue && npm run test:protocol && npm run test:fair-play && npm run test:engine-filter && npm run test:evaluation && npm run test:difficulty && npm run test:terminal && npm run test:time-policy && npm run test:search-policy && npm run test:promotion && npm run test:training-hint && npm run test:training-machine && npm run test:board-arrows && npm run test:ownership && npm run test:layout && npm run test:controller && npm run test:setup && npm run test:fair-play-ui && npm run test:training-ui && npm run test:analysis-ui && npm run test:live-data && npm run test:result-acknowledgment"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "ts-node": "^10.9.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.42",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
