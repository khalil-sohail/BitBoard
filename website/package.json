{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "dev:engine": "make -C ../engine",
    "dev:server": "ENGINE_PATH=../engine/chess-engine ts-node --project tsconfig.server.json server.ts",
    "dev:all": "npm run dev:engine && npm run dev:server",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-chessboard": "^5.10.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "ts-node": "^10.9.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.42",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
