{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "dev:engine": "make -C ../engine",
    "dev:server": "ENGINE_PATH=../engine/chess-engine ts-node --project tsconfig.server.json server.ts",
    "dev:all": "npm run dev:engine && npm run dev:server",
    "build": "next build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "next start",
    "start:server": "node dist/server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "ts-node": "^10.9.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.42",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
