# ACME / Nginx Proxy configuration
VIRTUAL_HOST=your-domain.com
LETSENCRYPT_HOST=your-domain.com
DEFAULT_EMAIL=admin@your-domain.com

# Docker image registry
REGISTRY=ghcr.io/your-github-user
GITHUB_USER=your-github-user
IMAGE_TAG=latest
CR_PAT=your_github_personal_access_token

# droplet info
SSH_USER=root
DROPLET_IP=your-droplet-public-ip

# Application service ports. Docker Compose reads this file from ./deploy.
# nginx remains fixed on public ports 80 and 443; SSH remains fixed on 22.
ENGINE_PATH=/app/engine/chess-engine
FRONTEND_PORT=3000
BACKEND_PORT=3001
NODE_ENV=production
BACKEND_ONLY=true
ENGINE_DEBUG=false

# Frontend/WebSocket routing
# The browser uses same-origin /api/engine through nginx-proxy.
